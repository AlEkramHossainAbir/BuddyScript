# Server Configuration
PORT=8000
NODE_ENV=development

# MongoDB Configuration (REQUIRED - Generate fresh credentials)

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/buddyscript?retryWrites=true&w=majority

# JWT Configuration (REQUIRED - Generate a strong unique secret)
JWT_SECRET=your-strong-random-secret-key-here

# Google OAuth Configuration (Required for Google Authentication)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=postmessage

# Client URL (Update with your Vercel deployment URL after deployment)
CLIENT_URL=http://localhost:3000,https://buddy-script-opal.vercel.app/


